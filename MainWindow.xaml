<Window x:Class="StopwatchApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stopwatch"
        Width="480" Height="310"
        MinWidth="480" MinHeight="310"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Icon="app.ico"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="BtnStart" TargetType="Button">
            <Setter Property="Background" Value="#4CC2FF"/>
            <Setter Property="Foreground" Value="#031825"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6DCDFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3AAFEC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnReset" TargetType="Button">
            <Setter Property="Background" Value="#2E2E2E"/>
            <Setter Property="Foreground" Value="#C8C8C8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#383838"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E"
            CornerRadius="20"
            BorderBrush="#28FFFFFF"
            BorderThickness="0.5"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="28,22,28,8">
                <TextBlock Text="STOPWATCH"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           FontWeight="Normal"
                           Foreground="#50FFFFFF"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="24" Height="24"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="Đóng">
                    <TextBlock Text="✕" FontSize="13" Foreground="#60FFFFFF"/>
                </Button>
            </Grid>

            <!-- Timer -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="28,8,28,20">
                <TextBlock x:Name="tbHours"
                           Text="00"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="68"
                           Foreground="#F5F5F5"
                           Width="95"
                           TextAlignment="Center"/>
                <TextBlock Text=":"
                           FontFamily="Segoe UI"
                           FontWeight="Light"
                           FontSize="52"
                           Foreground="#30FFFFFF"
                           VerticalAlignment="Bottom"
                           Margin="2,0,2,6"/>
                <TextBlock x:Name="tbMinutes"
                           Text="00"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="68"
                           Foreground="#F5F5F5"
                           Width="95"
                           TextAlignment="Center"/>
                <TextBlock Text=":"
                           FontFamily="Segoe UI"
                           FontWeight="Light"
                           FontSize="52"
                           Foreground="#30FFFFFF"
                           VerticalAlignment="Bottom"
                           Margin="2,0,2,6"/>
                <TextBlock x:Name="tbSeconds"
                           Text="00"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="68"
                           Foreground="#F5F5F5"
                           Width="95"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- Divider -->
            <Rectangle Grid.Row="2" Height="0.5" Fill="#14FFFFFF" Margin="28,0"/>

            <!-- Last record -->
            <StackPanel Grid.Row="3" Margin="28,14,28,20">
                <TextBlock Text="KẾT QUẢ GẦN NHẤT"
                           FontFamily="Segoe UI"
                           FontSize="10"
                           Foreground="#45FFFFFF"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="tbLastRecord"
                           Text="--"
                           FontFamily="Segoe UI"
                           FontSize="16"
                           Foreground="#BDBDBD"/>
            </StackPanel>

            <!-- Buttons -->
            <Grid Grid.Row="4" Margin="28,0,28,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnStartStop"
                        Grid.Column="0"
                        Style="{StaticResource BtnStart}"
                        Content="▶  Start"
                        Click="BtnStartStop_Click"/>
                <Button Grid.Column="2"
                        Style="{StaticResource BtnReset}"
                        Content="↺  Reset"
                        Click="BtnReset_Click"/>
            </Grid>

        </Grid>
    </Border>
</Window>
